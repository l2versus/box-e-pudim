{
  "name": "brazilian-pudding-api",
  "version": "0.1.0",
  "description": "Backend Fastify + Prisma + Postgres para Brazilian Pudding / Box InHouse",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:up": "docker compose up -d && echo waiting postgres... && sleep 3",
    "db:down": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed-dev.js",
    "db:seed:prod": "node prisma/seed-prod.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.0",
    "fastify": "^4.28.1",
    "fastify-type-provider-zod": "^2.0.0",
    "jose": "^5.9.6",
    "pg-boss": "^10.1.5",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "vitest": "^2.1.4"
  },
  "prisma": {
    "seed": "node prisma/seed-dev.js"
  }
}
